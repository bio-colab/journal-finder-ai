{
  "name": "journal-finder-ai",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "AI-powered academic journal finder that analyzes research abstracts and matches them with the best suitable journals using OpenAlex + LLM (Gemini/Mistral/OpenRouter). Special focus on Arabic and Iraqi journals.",
  "author": "Elias Sharar",
  "license": "MIT",
  "keywords": [
    "journal-finder",
    "academic-journals",
    "openalex",
    "gemini",
    "research-tools",
    "arabic-journals",
    "iraqi-journals",
    "journal-recommendation"
  ],
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "tailwind-merge": "^3.6.0",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
